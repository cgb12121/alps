# Copy thành .env và sửa giá trị. Docker Compose đọc .env khi chạy.

# MySQL (MYSQL_USER không được đặt "root" – image MySQL từ chối)
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=alps
MYSQL_USER=dev
MYSQL_PASSWORD=dev
MYSQL_PORT=3306

# Zeebe (Camunda 8)
ZEEBE_IMAGE=camunda/zeebe:8.5.0
ZEEBE_GRPC_PORT=26500
